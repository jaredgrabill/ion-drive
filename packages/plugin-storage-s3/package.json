{
  "name": "@ion-drive/plugin-storage-s3",
  "version": "0.1.0",
  "description": "Ion Drive plugin: S3-compatible storage provider — swaps the platform's filesystem blob store for AWS S3, MinIO, Cloudflare R2, or any S3-compatible endpoint, with pre-signed download URLs.",
  "license": "Apache-2.0",
  "author": "IonShift Technologies LLC",
  "homepage": "https://github.com/jaredgrabill/ion-drive",
  "repository": {
    "type": "git",
    "url": "https://github.com/jaredgrabill/ion-drive.git",
    "directory": "packages/plugin-storage-s3"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "NOTICE"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist *.tsbuildinfo"
  },
  "keywords": ["ion-drive", "plugin", "storage", "s3", "minio", "r2"],
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/lib-storage": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0"
  },
  "peerDependencies": {
    "@ion-drive/core": ">=0.2.0 <1.0.0"
  },
  "devDependencies": {
    "@ion-drive/core": "workspace:^",
    "@types/node": "^22.10.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
