{
  "name": "@ion-drive/plugin-redis",
  "version": "0.1.0",
  "description": "Ion Drive plugin: Redis cache and (opt-in) Redis Streams message bus — swaps the platform's CacheProvider for multi-node coherence and can replace the Postgres outbox bus for broker-based event delivery.",
  "license": "Apache-2.0",
  "author": "IonShift Technologies LLC",
  "homepage": "https://github.com/jaredgrabill/ion-drive",
  "repository": {
    "type": "git",
    "url": "https://github.com/jaredgrabill/ion-drive.git",
    "directory": "packages/plugin-redis"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "NOTICE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist *.tsbuildinfo"
  },
  "keywords": [
    "ion-drive",
    "plugin",
    "redis",
    "cache",
    "message-bus",
    "streams"
  ],
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "ioredis": "^5.4.0"
  },
  "peerDependencies": {
    "@ion-drive/core": ">=0.2.0 <1.0.0"
  },
  "devDependencies": {
    "@ion-drive/core": "workspace:^",
    "@types/node": "^22.10.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
