{
  "name": "ion-drive",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source, self-hosted platform for accelerated custom business software development",
  "keywords": [
    "backend",
    "platform",
    "headless-cms",
    "erp",
    "mcp",
    "llm",
    "typescript",
    "postgresql",
    "open-source"
  ],
  "homepage": "https://github.com/ionshift/ion-drive",
  "repository": {
    "type": "git",
    "url": "https://github.com/ionshift/ion-drive.git"
  },
  "author": "IonShift Technologies LLC",
  "license": "Apache-2.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "test:integration": "turbo run test:integration",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format --write .",
    "clean": "turbo run clean && rimraf node_modules",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "rimraf": "^6.0.0",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  }
}
