{
  "name": "@ion-drive/plugin-sendgrid",
  "version": "0.1.0",
  "description": "Ion Drive plugin: SendGrid email provider — swaps the platform's EmailProvider for real outbound delivery via the SendGrid v3 API. Zero runtime dependencies.",
  "license": "Apache-2.0",
  "author": "IonShift Technologies LLC",
  "homepage": "https://github.com/jaredgrabill/ion-drive",
  "repository": {
    "type": "git",
    "url": "https://github.com/jaredgrabill/ion-drive.git",
    "directory": "packages/plugin-sendgrid"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "NOTICE"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist *.tsbuildinfo"
  },
  "keywords": ["ion-drive", "plugin", "sendgrid", "email"],
  "peerDependencies": {
    "@ion-drive/core": ">=0.2.0 <1.0.0"
  },
  "devDependencies": {
    "@ion-drive/core": "workspace:^",
    "@types/node": "^22.10.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
