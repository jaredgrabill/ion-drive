# Ion Drive — environment configuration example
#
# Copy to `.env` and adjust. Every variable is optional; the defaults shown
# are what the server uses when a variable is unset. Ground truth for all
# names and defaults: packages/core/src/config/index.ts.
#
# Boolean variables are parsed strictly: true/1/yes/on enable, false/0/no/off
# disable (case-insensitive). Any other value refuses to boot with an error
# naming the variable — a misspelling never silently flips a flag.

# --- Database ---
# PostgreSQL connection URL for the system/tenant database.
# (DATABASE_URL is honored as a fallback.)
ION_DATABASE_URL=postgresql://ion:ion@localhost:5432/ion_drive
# If 5432 is already taken on your machine, start the dev Postgres on another
# host port — `ION_PG_PORT=55432 docker compose -f docker/docker-compose.yml up -d`
# — and change the port in ION_DATABASE_URL above to match.

# --- Server ---
# Port and host the Fastify server binds to. (PORT is honored as a fallback.)
ION_PORT=3000
ION_HOST=0.0.0.0
# Log level: fatal | error | warn | info | debug | trace
ION_LOG_LEVEL=info
# CORS allowed origins (single origin string). Defaults to same-origin only;
# a wildcard (true/*) is refused at boot because credentials are always sent.
# Set this to a separate frontend origin if you have one.
# ION_CORS_ORIGINS=http://localhost:5173
# Fastify trustProxy — honor X-Forwarded-* when behind a reverse proxy you
# control: true | false | hop count (1) | trusted addresses/CIDRs.
ION_TRUST_PROXY=false
# Public base URL of this server (used as the auth baseURL) and the admin
# console URL (used for CORS/redirects). Optional.
# ION_PUBLIC_URL=https://ion.example.com
# ION_ADMIN_URL=https://admin.example.com

# --- Auth & RBAC ---
# When true, RBAC is enforced on data/schema/admin endpoints. Leaving it off
# leaves every endpoint anonymous. A production server (NODE_ENV=production)
# refuses to boot with this off unless ION_ALLOW_OPEN=true is also set.
# (Projects scaffolded with `ion-drive init` default this to true.)
ION_REQUIRE_AUTH=false
# DANGER: acknowledge a deliberately open (no-auth) production deployment so
# the boot guard above allows it. Never set this on an internet-facing server.
# ION_ALLOW_OPEN=false
# Whether the built-in "public" role is evaluated for anonymous (no-credential)
# requests under ION_REQUIRE_AUTH=true. Default on but inert: the role is
# seeded with zero grants, so nothing is publicly readable until an admin
# grants read on a specific object to it (it can only ever hold read grants
# on named data objects). Set false to hard-disable anonymous evaluation.
# ION_PUBLIC_ROLE=true
# Bootstrap the admin account from the environment (recommended for public
# deployments): on a database with zero users, boot creates this account via
# the normal signup path (Better Auth hashing + password policy) and grants it
# admin — and public signup starts LOCKED (ION_DISABLE_SIGNUP defaults to true
# while these are set; set it to false explicitly to keep signup open). Once
# any user exists the vars are ignored (info log), so they are safe to leave
# set. Use ION_ADMIN_PASSWORD_FILE for secret mounts (file contents, trimmed);
# set exactly one of the two password sources.
# ION_ADMIN_EMAIL=you@example.com
# ION_ADMIN_PASSWORD=a-strong-password
# ION_ADMIN_PASSWORD_FILE=/run/secrets/ion-admin-password
# When true, public signup closes once the first admin exists (the first
# user can still sign up and becomes admin). Without ION_ADMIN_EMAIL it
# defaults to false. Leave it unset when using the admin bootstrap above —
# an explicit false here would override the locked-by-default behavior.
# ION_DISABLE_SIGNUP=false
# Anonymous (guest) sign-in: POST /api/auth/sign-in/anonymous mints a real
# user flagged isAnonymous with the seeded `anonymous` role (no grants until
# an admin edits it), upgradeable later via a normal signup from the guest
# session. Opt-in — it lets unauthenticated visitors create users. See
# docs/concepts/auth.md. Note: ION_DISABLE_SIGNUP also blocks the guest
# UPGRADE path (it closes /api/auth/sign-up/*).
ION_ANONYMOUS_AUTH=false
# Secret used to sign auth sessions/tokens (min 16 chars). Falls back to the
# encryption key when unset.
# ION_AUTH_SECRET=change-me-to-a-long-random-string

# --- Rate limiting ---
# Per-IP HTTP rate limiting (global bucket + stricter auth bucket).
ION_RATE_LIMIT_ENABLED=true
# Max requests per IP per window for the global bucket.
ION_RATE_LIMIT_MAX=300
# Window length in milliseconds (shared by both buckets).
ION_RATE_LIMIT_WINDOW_MS=60000
# Stricter max requests per IP per window for /api/auth/* endpoints.
ION_RATE_LIMIT_AUTH_MAX=20

# --- Secrets encryption ---
# AES-256-GCM key for the secrets manager: 32 bytes as a 64-char hex string.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ION_ENCRYPTION_KEY=<64-char-hex-string>

# --- Observability (Phase 5) ---
# Prometheus scrape endpoint at /metrics (independent of OTel).
ION_METRICS_ENABLED=true
# Optional bearer token required on GET /metrics (unset = open endpoint;
# keep it network-internal in that case).
# ION_METRICS_TOKEN=<long-random-string>
# Master switch for the OpenTelemetry SDK (traces + logs + OTLP metrics export).
ION_OTEL_ENABLED=false
# OTLP/HTTP base endpoint (signal paths /v1/traces, /v1/logs are appended).
ION_OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# Logical service name on every span/metric/log.
ION_OTEL_SERVICE_NAME=ion-drive
# Per-signal switches (all require ION_OTEL_ENABLED=true).
ION_OTEL_TRACES_ENABLED=true
ION_OTEL_LOGS_ENABLED=false
ION_OTEL_METRICS_ENABLED=false
# Max entries held by the in-memory log buffer backing /api/v1/logs.
ION_LOG_BUFFER_SIZE=2000

# --- Scheduled tasks (Phase 5) ---
ION_TASKS_ENABLED=true

# --- Admin console (Phase 14) ---
# Serve the built admin SPA at /admin when @ion-drive/admin (or
# ION_ADMIN_DIST) is present.
ION_ADMIN_ENABLED=true
# Explicit path to a built admin dist/ (overrides the package lookup).
# ION_ADMIN_DIST=./packages/admin/dist

# --- Building blocks (Phase 6) ---
ION_BLOCKS_ENABLED=true

# --- Events & plugins (Phase 9) ---
# Message bus + CRUD change events (Postgres outbox + dispatcher).
ION_EVENTS_ENABLED=true
# Fallback poll interval (ms) for the event dispatcher.
ION_EVENTS_POLL_INTERVAL_MS=2000
# Comma-separated plugin module specifiers to load at boot.
# ION_PLUGINS=@ion-drive/plugin-redis,@ion-drive/plugin-sendgrid

# --- File storage ---
# Root directory for the default filesystem blob store (StorageProvider).
# The @ion-drive/plugin-storage-s3 plugin makes this irrelevant.
ION_STORAGE_DIR=.ion-storage

# --- First-party plugin settings (only read when the plugin is loaded) ---
# @ion-drive/plugin-redis: connection URL (REDIS_URL also honored) and the
# opt-in bus swap (trades the transactional outbox + /api/v1/events surfaces
# for Redis Streams delivery — see the plugin README before enabling).
# ION_REDIS_URL=redis://localhost:6379
# ION_REDIS_BUS=false
# @ion-drive/plugin-sendgrid: API key + default sender.
# SENDGRID_API_KEY=SG.xxxxx
# SENDGRID_FROM=no-reply@example.com
# @ion-drive/plugin-storage-s3: bucket (required), region/endpoint/credentials.
# ION_S3_BUCKET=my-bucket
# ION_S3_REGION=us-east-1
# ION_S3_ENDPOINT=http://localhost:9000
# ION_S3_FORCE_PATH_STYLE=true
# ION_S3_ACCESS_KEY_ID=minioadmin
# ION_S3_SECRET_ACCESS_KEY=minioadmin
# ION_S3_KEY_PREFIX=
