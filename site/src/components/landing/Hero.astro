---
/**
 * Hero — the "Deep Field" thesis: a vast dark field where the only bright
 * objects are the headline and the glowing terminal. Copy is the launch-plan
 * wedge sentence, lifted from README.md — never invented.
 */
import Terminal from './Terminal.astro';
---

<section class="hero">
  <div class="container">
    <h1>
      The <span class="gradient-word">MCP-native</span> backend an AI agent stands up in minutes
    </h1>
    <p class="tagline">
      Self-hostable, open source. Your agent defines tables at runtime and gets REST, GraphQL,
      and MCP for free — and domain blocks land as editable code in your repo, not a marketplace
      lock-in.
    </p>
    <p class="triplet">
      self-hosted · MCP-native · secure by default · blocks you own as editable code
    </p>
    <div class="cta-row">
      <a class="btn btn-primary" href="/docs/getting-started/">Get started</a>
      <a class="btn external" href="https://github.com/jaredgrabill/ion-drive">GitHub</a>
    </div>
    <p class="license-line">Apache-2.0 · TypeScript · PostgreSQL 17 · Node 22+</p>
    <Terminal />
  </div>
</section>
