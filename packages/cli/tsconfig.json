{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src"
  },
  "include": ["src/**/*"],
  // __fixtures__ blocks are vendored INTO temp test projects at runtime (they
  // import @ion-drive/core from there) — never compiled as CLI sources.
  "exclude": ["node_modules", "dist", "src/block-test/__fixtures__"]
}
