{
  "uid": "ion-drive-overview",
  "title": "Ion Drive Overview",
  "description": "Starter dashboard for the Ion Drive platform metrics scraped from /metrics. Metric-name assumption: the OTel JS Prometheus serializer maps instrument dots to underscores and appends _total to counters, but does NOT append unit suffixes — e.g. ion.http.server.duration (unit: ms) becomes ion_http_server_duration_bucket/_sum/_count with values in milliseconds.",
  "tags": ["ion-drive"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Request rate",
      "description": "HTTP requests per second by API surface (rest / graphql / mcp / schema / admin / auth). Source: ion_http_server_requests_total.",
      "datasource": { "type": "prometheus", "uid": "ion-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "reqps",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (ion_surface) (rate(ion_http_server_requests_total[$__rate_interval]))",
          "legendFormat": "{{ion_surface}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Request duration p95",
      "description": "95th percentile HTTP request duration by API surface, in milliseconds (the ion.http.server.duration histogram records ms). Source: ion_http_server_duration_bucket.",
      "datasource": { "type": "prometheus", "uid": "ion-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "ms",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, ion_surface) (rate(ion_http_server_duration_bucket[$__rate_interval])))",
          "legendFormat": "{{ion_surface}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Error rate (5xx)",
      "description": "HTTP responses with a 5xx status code, per second, by API surface. Source: ion_http_server_requests_total{http_response_status_code=~\"5..\"}.",
      "datasource": { "type": "prometheus", "uid": "ion-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "reqps",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (ion_surface) (rate(ion_http_server_requests_total{http_response_status_code=~\"5..\"}[$__rate_interval]))",
          "legendFormat": "{{ion_surface}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Schema changes",
      "description": "Schema mutations applied (object create/alter/drop, field add/modify, ...), by change kind. Source: ion_schema_changes_total.",
      "datasource": { "type": "prometheus", "uid": "ion-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short",
          "min": 0,
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 60,
            "showPoints": "never",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (ion_schema_change) (increase(ion_schema_changes_total[$__rate_interval]))",
          "legendFormat": "{{ion_schema_change}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Task runs",
      "description": "Scheduled/background task runs by task and outcome. Source: ion_task_runs_total.",
      "datasource": { "type": "prometheus", "uid": "ion-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short",
          "min": 0,
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 60,
            "showPoints": "never",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (ion_task_name, ion_outcome) (increase(ion_task_runs_total[$__rate_interval]))",
          "legendFormat": "{{ion_task_name}} ({{ion_outcome}})"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Task duration p95",
      "description": "95th percentile task run duration by task, in milliseconds (the ion.task.duration histogram records ms). Source: ion_task_duration_bucket.",
      "datasource": { "type": "prometheus", "uid": "ion-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "ms",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, ion_task_name) (rate(ion_task_duration_bucket[$__rate_interval])))",
          "legendFormat": "{{ion_task_name}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Event publishes",
      "description": "Events published to the message-bus outbox, per second, by topic. Source: ion_event_published_total.",
      "datasource": { "type": "prometheus", "uid": "ion-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "cps",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (ion_event_topic) (rate(ion_event_published_total[$__rate_interval]))",
          "legendFormat": "{{ion_event_topic}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Event deliveries",
      "description": "Message-bus deliveries to consumer groups, per second, by consumer and outcome. Source: ion_event_deliveries_total.",
      "datasource": { "type": "prometheus", "uid": "ion-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "cps",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (ion_event_consumer, ion_outcome) (rate(ion_event_deliveries_total[$__rate_interval]))",
          "legendFormat": "{{ion_event_consumer}} ({{ion_outcome}})"
        }
      ]
    }
  ]
}
